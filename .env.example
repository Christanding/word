# Environment Variables Template

# DO NOT commit this file with real values. Copy to .env.local and fill in your values.

# Session
SESSION_SECRET=your-session-secret-key-here

# Admin (single-user allowlist)
ADMIN_EMAIL=your-email@example.com
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=your-bcrypt-password-hash-here

# Mock mode (set to "1" to enable, "0" to disable)
MOCK_OCR=1
MOCK_LLM=1

# Tencent Cloud OCR (required when MOCK_OCR=0)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou

# Alibaba DashScope / Qwen (required when MOCK_LLM=0)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# DeepSeek (preferred for definitions when provided)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Worker secret for background task authentication
WORKER_SECRET=your-worker-secret-key-here

# Limits and quotas
MAX_FILE_MB=50
MAX_PDF_PAGES=100
MAX_WORDS_PER_DOC=1000
DAILY_OCR_PAGES=100
DAILY_LLM_TOKENS=100000
